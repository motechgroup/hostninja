<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct web access to sensitive directories and config files
    RewriteRule ^(\.env|\.git|composer\.(json|lock)|package\.(json|lock)|storage|app|bootstrap|config|database|resources|routes) - [F,L,NC]

    # Handle Front Controller routing to public directory
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

<IfModule !mod_rewrite.c>
    <IfModule mod_alias.c>
        RedirectMatch 302 ^/$ /public/
    </IfModule>
</IfModule>
